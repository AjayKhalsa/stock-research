# StockLens environment — copy to .env in the repo root and fill in values.
# Backend loads this automatically (see backend/main.py).

# Required for AI thesis generation (optional — app works without it)
GEMINI_API_KEY=

# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional Kite Connect (legacy — not required; prices use Yahoo Finance)
# KITE_API_KEY=
# KITE_ACCESS_TOKEN=

# ── Frontend (copy to frontend/.env.local for Create React App) ──
# REACT_APP_API_URL=http://localhost:8000
